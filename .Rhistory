setwd(dirname(dirname(rstudioapi::getSourceEditorContext()$path)))
df_labels <- data.frame(
participant = 1:4,
age         = c(25L, 34L, 28L, 41L),
height      = c(170.5, 182.0, 165.3, 178.8),
active      = c(TRUE, FALSE, TRUE, TRUE),
city        = c("Sydney", "Melbourne", "Brisbane", "Perth"),
stringsAsFactors = FALSE
)
# Creates RDS test files for variable labels, value labels, and timezone.
# Run from the repo root:  Rscript local/create_testdata.R
#
# Requires the haven package for value labels:
#   install.packages("haven")
setwd(dirname(dirname(rstudioapi::getSourceEditorContext()$path)))
# or from command line just run from repo root
# ── 1. Variable labels ────────────────────────────────────────────────────────
# Tests attr(col, "label") on integer, double, logical, and character columns.
df_labels <- data.frame(
participant = 1:4,
age         = c(25L, 34L, 28L, 41L),
height      = c(170.5, 182.0, 165.3, 178.8),
active      = c(TRUE, FALSE, TRUE, TRUE),
city        = c("Sydney", "Melbourne", "Brisbane", "Perth"),
stringsAsFactors = FALSE
)
attr(df_labels$participant, "label") <- "Participant ID"
attr(df_labels$age,         "label") <- "Age in years"
attr(df_labels$height,      "label") <- "Height in centimetres"
attr(df_labels$active,      "label") <- "Currently active participant"
attr(df_labels$city,        "label") <- "City of residence"
saveRDS(df_labels, "testdata/dataframe_labels.rds")
write.csv(df_labels, "testdata/dataframe_labels.csv", row.names = FALSE)
# ── 2. Value labels (haven_labelled) ─────────────────────────────────────────
# Tests attr(col, "labels") named vector and attr(col, "label") together.
# The column values are integer codes; the labels map codes to text.
library(haven)
df_vallabels <- data.frame(
id = 1:5,
gender = haven::labelled(
c(1L, 2L, 1L, 2L, 1L),
labels = c(Male = 1L, Female = 2L),
label  = "Gender of participant"
),
status = haven::labelled(
c(1L, 1L, 2L, 3L, 2L),
labels = c(Active = 1L, Inactive = 2L, Pending = 3L),
label  = "Account status"
)
)
saveRDS(df_vallabels, "testdata/dataframe_vallabels.rds")
# CSV shows the underlying integer codes, not the labels.
write.csv(as.data.frame(lapply(df_vallabels, as.integer)),
"testdata/dataframe_vallabels.csv", row.names = FALSE)
# ── 3. Timezone ───────────────────────────────────────────────────────────────
# Tests attr(col, "tzone") on a POSIXct column.
# rds-js converts POSIXct to UTC ISO strings; tzone is preserved as metadata.
df_tz <- data.frame(
event = c("Morning standup", "Lunch break", "End of day"),
scheduled = as.POSIXct(
c("2024-03-15 09:00:00", "2024-03-15 12:30:00", "2024-03-15 17:45:00"),
tz = "America/New_York"
)
)
attr(df_tz$scheduled, "label") <- "Scheduled time (Eastern)"
saveRDS(df_tz, "testdata/dataframe_tz.rds")
# CSV shows the UTC ISO strings that rds-js produces.
# Generate these by running the app or use format() directly:
write.csv(
data.frame(
event     = df_tz$event,
scheduled = format(df_tz$scheduled, "%Y-%m-%dT%H:%M:%S.000Z", tz = "UTC")
),
"testdata/dataframe_tz.csv", row.names = FALSE
)
